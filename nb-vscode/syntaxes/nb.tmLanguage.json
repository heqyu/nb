{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NB",
  "scopeName": "source.nb",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nb",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nb",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.nb" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.nb" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nb",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.nb" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.nb" }
          },
          "patterns": [
            {
              "name": "meta.embedded.nb",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.embedded.begin.nb" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.embedded.end.nb" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            },
            {
              "name": "constant.character.escape.nb",
              "match": "\\\\[\"\\\\nrt]"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nb",
          "match": "\\b(if|else|for|while|in|return|break|continue|throw)\\b"
        },
        {
          "name": "keyword.declaration.nb",
          "match": "\\b(let|mut|fn|class|mixin)\\b"
        },
        {
          "name": "keyword.operator.nb",
          "match": "\\b(is|and|or|not)\\b"
        },
        {
          "name": "keyword.other.nb",
          "match": "\\b(self|protect|async|await|export|require|throws)\\b"
        },
        {
          "name": "constant.language.nb",
          "match": "\\b(nil|true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nb",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.nb",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.nb",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.nb",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
