    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "lldb",
            "request": "attach",
            "name": "Attach",
            "program": "${workspaceFolder}/target/debug/nb-lsp.exe"
        },

        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in library 'nb_core'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=nb-core"
                ],
                "filter": {
                    "name": "nb_core",
                    "kind": "lib"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'nb'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=nb",
                    "--package=nb"
                ],
                "filter": {
                    "name": "nb",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'nb'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=nb",
                    "--package=nb"
                ],
                "filter": {
                    "name": "nb",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'nb-lsp'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=nb-lsp",
                    "--package=nb-lsp"
                ],
                "filter": {
                    "name": "nb-lsp",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'nb-lsp'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=nb-lsp",
                    "--package=nb-lsp"
                ],
                "filter": {
                    "name": "nb-lsp",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}