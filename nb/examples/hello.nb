// 基础测试
let name = "NB"
print("hello ${name}!")


// 数学
let mut x = 10
x += 5
print(x)

// 函数
fn add(a, b) {
    return a + b
}
print(add(3, 4))

// 数组
let mut arr = [1, 2, 3, 4, 5]
arr.push(6)
print(len(arr))

// for range
for i in 0..3 {
    print(i)
}

for i, v in "hello"{
    print(i, v)
}

// class：只声明字段，方法定义在外部
class Animal {
    name: string
    mut hp: number
}

fn Animal.speak(self) {
    print("${self.name} says hello, hp=${self.hp}")
}

// 结构体字面量初始化
let mut a = Animal { name = "cat", hp = 100 }
a.speak()

// protect
let err, result = protect {
    return add(10, 20)
}
if err != nil {
    print("error: ${err}")
} else {
    print("result: ${result}")
}

// protect 捕获错误
let err2 = protect {
    throw "oops"
}
print("caught: ${err2}")

// 三元运算
let score = 85
let grade = score >= 90 ? "A" : "B"
print("grade: ${grade}")

// 类型检查
print(type(42))
print(type("hello"))
print(type(a))
print(type(Animal))
